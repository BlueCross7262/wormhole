{
  "name": "wormhole",
  "version": "0.5.1",
  "description": "Claude Code 전역 설정을 머신 간 동기화하는 CLI / 플러그인 커맨드",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "wormhole": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:plugin": "node scripts/build-plugin.mjs",
    "dev": "tsx src/cli.ts",
    "dev:server": "tsx src/index.ts",
    "start": "node dist/cli.js",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "test:e2e": "tsx --test \"test/**/*.test.ts\"",
    "test:mcp": "tsx --test test/mcp/smoke.test.mjs test/mcp/contract.test.mjs test/mcp/twomachine.test.mjs test/mcp/twomachine2.test.mjs test/mcp/edge.test.mjs test/mcp/config2.test.mjs test/mcp/security.test.ts",
    "test:types": "tsc -p tsconfig.test.json --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scure/base": "^1.1.5",
    "age-encryption": "^0.2.3",
    "fast-glob": "^3.3.2",
    "webdav": "^5.7.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
