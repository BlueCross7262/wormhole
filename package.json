{
  "name": "claude-sync-mcp",
  "version": "0.1.0",
  "description": "Claude Code 전역 설정을 머신 간 동기화하는 MCP 서버",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-sync-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "test:types": "tsc -p tsconfig.test.json --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scure/base": "^1.1.5",
    "age-encryption": "^0.2.3",
    "chokidar": "^4.0.3",
    "fast-glob": "^3.3.2",
    "picomatch": "^2.3.2",
    "webdav": "^5.7.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
