{
  "_comment": "args[0]/CLAUDE_SYNC_CONFIG 는 절대경로로 지정한다(Windows: C:/Users/user/..., WSL2: /home/user/...). CLAUDE_SYNC_PASSPHRASE 를 여기 평문으로 넣는 대신 0600 권한의 passphrase 파일(<stateDir>/passphrase) 또는 keychain(secret-tool, env CLAUDE_SYNC_KEYCHAIN_SERVICE) 사용을 권장한다.",
  "mcpServers": {
    "claude-sync": {
      "command": "node",
      "args": ["/absolute/path/to/claude-sync-mcp/dist/index.js"],
      "env": {
        "CLAUDE_SYNC_CONFIG": "/absolute/path/to/config.json",
        "CLAUDE_SYNC_WEBDAV_PASS": "your-webdav-password",
        "CLAUDE_SYNC_PASSPHRASE": "",
        "CLAUDE_SYNC_LOG_LEVEL": "info"
      }
    }
  }
}
