# ── Dependencies ──────────────────────────────
node_modules/

# ── Build output ──────────────────────────────
dist/
*.tsbuildinfo

# ── Secrets / 암호화 자산 (절대 커밋 금지) ──────
# age 파생 키 · passphrase · 토큰
*.key
*.age
*.token
age-key.txt
passphrase

# 로컬 상태 디렉터리 (키 캐시 · 백업 포함)
.wormhole/

# 실제 설정 파일 (example 만 커밋, 실제는 비밀값 포함)
config.json
.mcp.json

# 환경변수 (example 은 유지)
.env
.env.*
!.env.example

# ── Logs ──────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ── Cache / temp ──────────────────────────────
.cache/
*.tmp
*.temp

# ── Editor / IDE ──────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

.serena/
.omc/

# ── 플러그인 배포 산출물 (plugin/ 서브트리는 커밋 — 루트 dist/·.mcp.json 무시 규칙의 예외) ──
# 설치 시 빌드 없이 동작하려면 번들과 MCP 등록 파일이 레포에 들어가야 한다.
!plugin/dist/
!plugin/dist/**
!plugin/.mcp.json

# ── graphify 도구 부산물 (이번 세션 생성, wormhole 소스 아님 — 추적 안 함) ──
graphify-out/
