{
  "_comment": "비밀값(WebDAV 비밀번호, passphrase)은 이 파일에 직접 입력하지 않는다. WebDAV 비밀번호는 env WORMHOLE_WEBDAV_PASS(또는 username=WORMHOLE_WEBDAV_USER, url=WORMHOLE_WEBDAV_URL), passphrase 는 env WORMHOLE_PASSPHRASE / 0600 파일 / keychain 으로 주입한다. passphrase 원문은 절대 이 파일이나 config.json 에 넣지 않는다.",
  "stateDir": "~/.wormhole",
  "remote": {
    "url": "https://your-webdav-server.example.com",
    "username": "your-webdav-username",
    "password": "",
    "remoteBaseDir": "/wormhole"
  },
  "crypto": {
    "_comment": "passphraseEnv: passphrase 를 읽을 환경변수 이름. passphraseFile/derivedKeyPath 는 빈 문자열이면 stateDir 기본값을 쓴다(passphraseFile=<stateDir>/passphrase, derivedKeyPath=<stateDir>/age-key.txt). kdfN 이 클수록 강하다(메모리 사용량 증가). N=65536=2^16 ≈ 64MB.",
    "passphraseEnv": "WORMHOLE_PASSPHRASE",
    "passphraseFile": "",
    "derivedKeyPath": "",
    "kdfN": 65536,
    "kdfR": 8,
    "kdfP": 1
  },
  "targets": {
    "include": [
      ".claude/CLAUDE.md",
      ".claude/settings.json",
      ".claude/skills/**",
      ".claude/agents/**",
      ".claude/commands/**",
      ".claude/.mcp.json"
    ],
    "exclude": [
      ".claude/.credentials.json",
      ".claude/settings.local.json",
      "**/*.token",
      "**/*.key",
      ".claude/projects/**",
      ".claude/todos/**",
      ".claude/statsig/**",
      ".claude/history/**",
      "**/*.log",
      "**/cache/**"
    ]
  },
  "settingsLocalKeys": [
    "mcpServers.*.command",
    "mcpServers.*.args",
    "mcpServers.*.cwd",
    "mcpServers.*.env",
    "permissions.*"
  ],
  "selfMcpServerNames": ["wormhole"],
  "conflictPolicy": "preserve-both",
  "autoSync": {
    "enabled": false,
    "debounceMs": 2000,
    "pullIntervalMs": 300000
  },
  "lock": {
    "ttlMs": 30000,
    "acquireRetries": 3,
    "acquireRetryDelayMs": 1000
  }
}
