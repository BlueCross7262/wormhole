{
  "stateDir": "~/.wormhole",
  "crypto": {
    "passphraseEnv": "WORMHOLE_PASSPHRASE",
    "passphraseFile": "",
    "derivedKeyPath": "",
    "kdfN": 65536,
    "kdfR": 8,
    "kdfP": 1
  },
  "targets": {
    "include": [
      ".claude/CLAUDE.md",
      ".claude/settings.json",
      ".claude/agents/**",
      ".claude/commands/**",
      ".claude/hud/**",
      ".claude/rules/**",
      ".claude/scripts/**",
      ".claude/hookify.*.global.md",
      ".claude/wormhole-config.json"
    ],
    "exclude": [
      ".claude/.credentials.json",
      ".claude/settings.local.json",
      "**/*.token",
      "**/*.key",
      ".claude/projects/**",
      ".claude/todos/**",
      ".claude/statsig/**",
      ".claude/history/**",
      "**/*.log",
      "**/cache/**"
    ]
  },
  "skills_keyword": "wormhole-sync",
  "syncMcpServers": [
    "whimsical-desktop",
    "microsoft.docs.mcp",
    "serena"
  ],
  "conflictPolicy": "preserve-both",
  "homeRootTargets": {
    ".claude.json": {
      "subkeys": [
        "mcpServers"
      ],
      "preserveMode": "denylist"
    }
  },
  "lock": {
    "ttlMs": 30000,
    "acquireRetries": 3,
    "acquireRetryDelayMs": 1000
  }
}
