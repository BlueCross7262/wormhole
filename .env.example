# ~/.wormhole/.env  (고정 위치; chmod 600)
# WebDAV 접속 정보 + 암호화 패스프레이즈를 플랫 단일 변수로 지정한다.
#
# ★ 이 파일 파서는 전체줄 # 주석만 지원한다.
#   KEY=val # 설명  형식의 인라인 # 은 값에 섞이므로 금지.
#   주석은 항상 별도 줄에 단독으로 작성한다.

# ── WebDAV 연결 ──────────────────────────────────────────────
# WebDAV 서버 URL — WebDAV 공유(share) 경로까지 포함해야 한다.
#   (예: https://nas.example.com/claude_code_sync)
#   Synology 등 NAS 는 루트가 읽기 전용이라, 쓰기는 공유 디렉터리 안에서만 된다.
WEBDAV_URL=https://nas.example.com/your-share

# WebDAV 계정 이름.
#   원격 기본 디렉터리는 이 값에서 자동 파생된다 (URL 아래 /<WEBDAV_USER>).
#   즉 최종 경로 = WEBDAV_URL + "/" + WEBDAV_USER.
#   별도 WEBDAV_BASEDIR 는 없다 — 필요 시 config.json 의 remote.remoteBaseDir 로만 override.
WEBDAV_USER=alice

# WebDAV 계정 비밀번호 (앱 비밀번호 권장)
WEBDAV_PASS=secret

# ── 암호화 패스프레이즈 (zero-knowledge) ─────────────────────
# age 키를 파생하는 마스터 시크릿. 서버에 절대 전송되지 않는다.
#   ⚠ WEBDAV_PASS 와 동일 값 사용 금지 — WEBDAV_PASS 는 서버가 아는 값이라,
#     재사용하면 서버가 salt + 그 값으로 age 키를 파생해 복호 가능 → zero-knowledge 붕괴.
#   모든 머신이 같은 passphrase 를 써야 동일 age 키가 파생된다 (salt 는 원격 keyparams.json 공유).
#   분실 시 복구 불가 — 비밀번호 관리자에 보관 권장.
# 방법 A: 환경변수 직접 지정 (가장 단순)
# WORMHOLE_PASSPHRASE=your-secret-passphrase
# 방법 B: 0600 권한 파일 경로 (기본값: ~/.wormhole/passphrase)
# WORMHOLE_PASSPHRASE_FILE=~/.wormhole/passphrase
# 방법 C: Linux/WSL2 keychain service 이름 (secret-tool)
# WORMHOLE_KEYCHAIN_SERVICE=wormhole

# ── 선택적 설정 ──────────────────────────────────────────────
# 로그 레벨 (debug | info | warn | error, 기본값: info)
# WORMHOLE_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# (optional) 동기화 대상 추가 지정 — config.json 기본값에 ADDITIVE UNION 된다.
#   보안 제외 목록 (*.key, *.token, .credentials.json, settings.local.json 등) 은
#   .env 로 제거할 수 없다. 제거하려면 config.json 의 targets.exclude 를 직접 편집한다.
#   쉼표 구분 glob 목록. 중괄호 확장 {a,b} 미지원 (쉼표가 구분자).
# WORMHOLE_SYNC_INCLUDE=.claude/plugins/known_marketplaces.json,.claude/extra/**
# WORMHOLE_SYNC_EXCLUDE=.claude/secret-notes/**
