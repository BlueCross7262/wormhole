# ~/.wormhole/.env  (고정 위치; chmod 600)
# WebDAV 접속 정보를 플랫 단일 변수로 지정한다.
#
# ★ 이 파일 파서는 전체줄 # 주석만 지원한다.
#   KEY=val # 설명  형식의 인라인 # 은 값에 섞이므로 금지.
#   주석은 항상 별도 줄에 단독으로 작성한다.

WEBDAV_URL=https://nas.example.com/dav
WEBDAV_USER=alice
WEBDAV_PASS=secret

# BASEDIR 는 선택 — 미지정 시 /wormhole 또는 config.json remote.baseDir 사용
# WEBDAV_BASEDIR=/wormhole

# WORMHOLE_PASSPHRASE=...   (optional; 0600 파일 / keychain 권장)

# ---------------------------------------------------------------------------
# (optional) 동기화 대상 추가 지정 — config.json 기본값에 ADDITIVE UNION 된다.
#   보안 제외 목록 (*.key, *.token, .credentials.json, settings.local.json 등) 은
#   .env 로 제거할 수 없다. 제거하려면 config.json 의 targets.exclude 를 직접 편집한다.
#   쉼표 구분 glob 목록. 중괄호 확장 {a,b} 미지원 (쉼표가 구분자).
# WORMHOLE_SYNC_INCLUDE=.claude/plugins/known_marketplaces.json,.claude/extra/**
# WORMHOLE_SYNC_EXCLUDE=.claude/secret-notes/**
